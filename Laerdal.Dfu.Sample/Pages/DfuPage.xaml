<?xml version="1.0" encoding="utf-8"?>

<base:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                      xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                      xmlns:base="clr-namespace:Laerdal.Dfu.Sample.Infrastructure"
                      xmlns:vm="clr-namespace:Laerdal.Dfu.Sample.ViewModels"
                      x:Class="Laerdal.Dfu.Sample.Pages.DfuPage"
                      x:TypeArguments="vm:DfuViewModel"
                      x:DataType="vm:DfuViewModel"
                      Title="DFU Update">

    <VerticalStackLayout Padding="16" Spacing="12">

        <!-- Device info -->
        <Border Padding="14" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}">
            <VerticalStackLayout Spacing="2">
                <Label Text="DEVICE" FontSize="11" CharacterSpacing="1.5"
                       TextColor="{AppThemeBinding Light=#8E8E93, Dark=#8E8E93}" />
                <Label Text="{Binding DeviceName}" FontAttributes="Bold" FontSize="17" />
                <Label Text="{Binding DeviceAddress}" FontSize="12"
                       TextColor="{AppThemeBinding Light=#8E8E93, Dark=#636366}" />
            </VerticalStackLayout>
        </Border>

        <!-- Firmware file selection -->
        <Border Padding="14" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}">
            <VerticalStackLayout Spacing="10">
                <Label Text="FIRMWARE FILE" FontSize="11" CharacterSpacing="1.5"
                       TextColor="{AppThemeBinding Light=#8E8E93, Dark=#8E8E93}" />
                <Label Text="{Binding FirmwareFileName}" FontSize="15"
                       TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Button Text="Select Firmware File (.zip / .bin)"
                        Command="{Binding SelectFileCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </Border>

        <!-- Progress + actions -->
        <Border Padding="14" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}">
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding StatusMessage}" FontSize="15"
                           TextColor="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                    <Label Grid.Column="1" Text="{Binding ProgressText}" FontSize="15"
                           FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                </Grid>
                <ProgressBar Progress="{Binding Progress}" HeightRequest="6" />
                <Button Text="Start DFU"
                        Command="{Binding StartDfuCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        HorizontalOptions="Fill" />
                <Button Text="Abort"
                        Command="{Binding AbortCommand}"
                        IsVisible="{Binding IsBusy}"
                        Style="{StaticResource DestructiveButton}"
                        HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </Border>

        <!-- Error panel -->
        <Border Padding="14" StrokeShape="RoundRectangle 10" StrokeThickness="1"
                Stroke="#C0392B"
                BackgroundColor="{AppThemeBinding Light=#FFF2F2, Dark=#3A1A1A}"
                IsVisible="{Binding HasError}">
            <VerticalStackLayout Spacing="4">
                <Label Text="ERROR" FontSize="11" CharacterSpacing="1.5" FontAttributes="Bold"
                       TextColor="#C0392B" />
                <Label Text="{Binding ErrorMessage}" FontSize="14" TextColor="#C0392B" />
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>

</base:BaseContentPage>
